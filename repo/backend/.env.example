NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost
DB_HOST=mysql
DB_PORT=3306
DB_USER=app_user
DB_PASSWORD=app_password
DB_NAME=incident_db
JWT_SECRET=change_me_to_a_random_string_at_least_32_chars
DATA_ENCRYPTION_KEY=change_me_64_hex_chars_representing_32_bytes
UPLOAD_DIR=/app/uploads
ENABLE_CRON=true
REQUIRE_HTTPS=true
